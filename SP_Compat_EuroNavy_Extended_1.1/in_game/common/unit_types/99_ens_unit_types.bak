# European Naval Superiority — Ship Types
#
# Part 1: Non-European Regional Variants
#   Strong in home waters, weaker in open-ocean artillery combat.
#   Large, crew-heavy, or fast, but carry fewer/lighter guns
#   and suffer penalties on ocean and deep ocean topography.
#
# Part 2: Western Shipbuilding Adoption (Catch-Up Ships)
#   Available to non-European nations one age behind the European
#   equivalents. Same stats as the originals, no ocean penalties.
#
# NOTE: All ships set buildable = yes to override the is_special default.
# Each ship has a location_potential gate restricting where it can be built.


##################################################
# PART 1: REGIONAL VARIANTS
##################################################


##################################################
# War Jongs — Southeast Asian heavy ships
# Large, crew-heavy, optimized for boarding in coastal waters.
# Vulnerable to European standoff gunnery in open ocean.
##################################################

# Southeast Asian war jong — large, crew-heavy, strong in coastal waters
# but vulnerable to standoff gunnery. Hull 35 (vs base 25), cannons 30 (vs 50),
# crew 0.500 (vs 0.300).
n_ens_war_jong = {
	is_special = yes
	category = navy_heavy_ship
	copy_from = n_age_3_discovery_heavy_ship
	upgrades_to = n_ens_great_jong
	buildable = yes

	location_potential = {
		ens_southeast_asian_location_trigger = yes
	}

	hull_size = 35
	cannons = 30
	crew_size = 0.500

	combat = {
		ocean = -0.25
		deep_ocean = -0.5
	}

	maintenance_demand = heavy_ship_3_maintenance
	construction_demand = heavy_ship_3_construction
	age = "age_3_discovery"
}

# Late-era war jong — massive displacement but still limited artillery.
# Hull 45 (vs base 30), cannons 40 (vs 60), crew 0.700 (vs 0.450).
# Upgrades into adopted galleon once Western shipbuilding is researched.
n_ens_great_jong = {
	is_special = yes
	category = navy_heavy_ship
	copy_from = n_age_4_reformation_heavy_ship
	upgrades_to = n_ens_adopted_galleon
	buildable = yes

	location_potential = {
		ens_southeast_asian_location_trigger = yes
	}

	hull_size = 45
	cannons = 40
	crew_size = 0.700

	combat = {
		ocean = -0.25
		deep_ocean = -0.5
	}

	maintenance_demand = heavy_ship_4_maintenance
	construction_demand = heavy_ship_4_construction
	age = "age_4_reformation"
}

##################################################
# Coastal Prau — Southeast Asian light ships
