##################################################
# PART 2: WESTERN SHIPBUILDING ADOPTION
##################################################
# Available to non-European nations one age behind the European
# equivalent. Same stats as the originals (via copy_from),
# representing successful technology transfer.
# No ocean combat penalties — the design is Western.
##################################################


######################
# Adopted Heavy Ships
######################

# Western-rigged carrack — European carrack design built by non-European
# shipyards. Same stats as the age 3 European carrack, available at age 4.
n_ens_adopted_carrack = {
	is_special = yes
	category = navy_heavy_ship
	copy_from = n_age_3_discovery_heavy_ship
	upgrades_to = n_ens_adopted_galleon
	buildable = yes

	location_potential = {
		ens_non_european_location_trigger = yes
	}

	age = "age_4_reformation"
}

# Adopted galleon — Western galleon design adapted by non-European nations.
# Same stats as the age 4 European galleon, available at age 5.
n_ens_adopted_galleon = {
	is_special = yes
	category = navy_heavy_ship
	copy_from = n_age_4_reformation_heavy_ship
	upgrades_to = n_ens_adopted_twodecker
	buildable = yes

	location_potential = {
		ens_non_european_location_trigger = yes
	}

	age = "age_5_absolutism"
}

# Adopted two-decker — Western two-decker design built overseas.
# Same stats as the age 5 European two-decker, available at age 6.
# Upgrades to the base game three-decker (ungated at age 6).
n_ens_adopted_twodecker = {
	is_special = yes
	category = navy_heavy_ship
	copy_from = n_age_5_absolutism_heavy_ship
	upgrades_to = n_threedecker
	buildable = yes

	location_potential = {
		ens_non_european_location_trigger = yes
	}

	age = "age_6_revolutions"
}

