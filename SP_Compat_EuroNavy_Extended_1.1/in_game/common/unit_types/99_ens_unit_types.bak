##################################################
# Chinese Junks — heavy ships with advanced construction
# Reasonably seaworthy but not ocean-optimized. Strong in inland seas.
##################################################

# Chinese imperial junk — advanced construction, moderate armament, strong
# in coastal defense. Hull 30 (vs base 25), cannons 35 (vs 50),
# crew 0.250 (vs 0.300). Bonus in inland seas, penalty in open ocean.
n_ens_imperial_junk = {
	is_special = yes
	category = navy_heavy_ship
	copy_from = n_age_3_discovery_heavy_ship
	upgrades_to = n_ens_treasure_junk
	buildable = yes

	location_potential = {
		ens_chinese_location_trigger = yes
	}

	hull_size = 30
	cannons = 35
	crew_size = 0.250

	combat = {
		ocean = -0.1
		deep_ocean = -0.3
		inland_sea = 0.15
	}

	maintenance_demand = heavy_ship_3_maintenance
	construction_demand = heavy_ship_3_construction
	age = "age_3_discovery"
}

# Late treasure junk — massive but conservative gunnery doctrine.
# Hull 50 (vs base 30), cannons 40 (vs 60), crew 0.350 (vs 0.450).
# Elevated maritime presence reflects prestige projection.
# Upgrades into adopted galleon once Western shipbuilding is researched.
n_ens_treasure_junk = {
	is_special = yes
	category = navy_heavy_ship
	copy_from = n_age_4_reformation_heavy_ship
	upgrades_to = n_ens_adopted_galleon
	buildable = yes

	location_potential = {
		ens_chinese_location_trigger = yes
	}

	hull_size = 50
	cannons = 40
	crew_size = 0.350
	maritime_presence = ship_above_medium_maritime

	combat = {
		ocean = -0.1
		deep_ocean = -0.3
		inland_sea = 0.15
	}

	maintenance_demand = heavy_ship_4_maintenance
	construction_demand = heavy_ship_4_construction
	age = "age_4_reformation"
}

