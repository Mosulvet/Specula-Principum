a_kerns = {
	is_special = yes
	category = army_infantry
	copy_from = a_age_1_traditions_infantry
	light = yes

	buildable = no
	levy = yes
	

	combat_speed = 0.1
	initiative = 6
	
	morale_damage_taken = 0.15 #new

	#root = location. Checks location_potential first so don't need that scripting in
	mercenaries_per_location = {
		pop_type = peasants
		multiply = 0.01
	}

	gfx_tags = { light_tag }
}

a_schiltron = {
	is_special = yes
	category = army_infantry
	copy_from = a_age_1_traditions_infantry
	light = yes

	frontage = -0.25
	combat_speed = -0.25
	morale_damage_taken = 0.10
	
	buildable = no
	levy = yes

	#root = location. Checks location_potential first so don't need that scripting in
	mercenaries_per_location = {
		pop_type = peasants
		multiply = 0.01
	}

	location_potential = {
		any_pop = {
			OR = {
				culture = culture:highland
				culture = culture:scottish
			}
		}
	}

	gfx_tags = { pike_tag light_tag }
	color = unit_rifle_green 
}

a_almogavars = {
	is_special = yes
	category = army_infantry
	copy_from = a_age_1_traditions_infantry
	upgrades_to = a_late_almogavars
	light = yes

	initiative = 2
	combat_speed = 0.05
	morale_damage_done = 0.1
	morale_damage_taken = 0.10
	
	
	buildable = no
	levy = yes


	#root = location. Checks location_potential first so don't need that scripting in

	mercenaries_per_location = {
		pop_type = peasants
		multiply = 0.01
	}

	location_potential = {
		unit_almogavars_location_trigger = yes
	}
	
	gfx_tags = { spear_tag light_tag }
}

a_gallowglass = {
	is_special = yes
	category = army_infantry

	copy_from = a_age_1_traditions_infantry
	upgrades_to = a_reformed_gallowglass
	
	strength_damage_taken = -0.05
	morale_damage_taken = -0.10	
	initiative = 2

	location_potential = {
		dominant_culture = culture:norse_gael
	}
	
	buildable = no
	levy = yes

	#root = location. Checks location_potential first so don't need that scripting in
	mercenaries_per_location = {
		pop_type = peasants
		multiply = 0.01
	}

	gfx_tags = { gallowglass_tag medium_tag }
}